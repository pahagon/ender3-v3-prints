#!/usr/bin/env bash
# Valida o nome da branch antes do push.
# Instalação: git config core.hooksPath .githooks

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
PATTERN="^(main|(feat|fix|docs|chore)/[a-z0-9][a-z0-9-]*)$"

if [[ ! "$BRANCH" =~ $PATTERN ]]; then
  echo ""
  echo "pre-push: branch '$BRANCH' não segue a convenção."
  echo ""
  echo "Formatos válidos:"
  echo "  feat/<descricao>"
  echo "  fix/<descricao>"
  echo "  docs/<descricao>"
  echo "  chore/<descricao>"
  echo ""
  echo "Regras: lowercase, hífens, sem espaços ou underscores."
  echo "Exemplo: feat/suporte-raspberry-pi4"
  echo ""
  exit 1
fi
